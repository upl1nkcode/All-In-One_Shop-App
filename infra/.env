# ============================================================
# AllInOne Shop — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=allinone_shop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Spring Boot Backend ---
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/allinone_shop
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=changeme
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-make-it-long
PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# --- Meilisearch ---
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=changeme-meili-master-key

# --- Next.js Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# --- Scraper ---
SCRAPER_API_URL=http://backend:8080/api
SCRAPER_API_KEY=changeme-scraper-key
